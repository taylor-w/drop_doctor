<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="DropDoctor watches your internet connection for drops, latency spikes and jitter, then shows where the fault lies — with proof you can screen-share."
    />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="DropDoctor" suffix=" · DropDoctor" phx-no-format>{assigns[:page_title]}</.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      // Theme has two independent dimensions, both persisted client-side and
      // applied here before paint (no flash):
      //   mode     — localStorage["phx:theme"]: "light" | "dark" | absent=system
      //   colorway — localStorage["tc:colorway"]: palette name | absent=default
      // The applied data-theme is the combination, e.g. "winter-dark"; the brand
      // "default" colorway stays the bare "light"/"dark" themes. We also mirror
      // mode/colorway onto <html> so the picker's pill + active-ring are pure CSS.
      (() => {
        const root = document.documentElement;
        const MODE = "phx:theme", CW = "tc:colorway";
        const mq = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)");
        const mode = () => {
          const m = localStorage.getItem(MODE);
          return m === "light" || m === "dark" ? m : (mq && mq.matches ? "dark" : "light");
        };
        const apply = () => {
          const cw = localStorage.getItem(CW) || "default";
          root.setAttribute("data-theme", cw === "default" ? mode() : cw + "-" + mode());
          root.setAttribute("data-mode", localStorage.getItem(MODE) || "system");
          root.setAttribute("data-colorway", cw);
        };
        apply();
        // Follow the OS in system mode, and any change made in another tab.
        if (mq) mq.addEventListener("change", () => {
          if (!["light", "dark"].includes(localStorage.getItem(MODE))) apply();
        });
        window.addEventListener("storage", (e) => (e.key === MODE || e.key === CW) && apply());
        window.addEventListener("phx:set-theme", (e) => {
          const m = e.target.dataset.phxTheme;
          m === "system" ? localStorage.removeItem(MODE) : localStorage.setItem(MODE, m);
          apply();
        });
        window.addEventListener("phx:set-colorway", (e) => {
          const c = e.target.dataset.colorway;
          !c || c === "default" ? localStorage.removeItem(CW) : localStorage.setItem(CW, c);
          apply();
        });
      })();
    </script>
    <script>
      // Stream-safe privacy + timezone. State lives on <html> (data-privacy /
      // data-tz); privacy is CSS-driven, times are reformatted client-side.
      (() => {
        const root = document.documentElement;
        root.setAttribute("data-privacy", localStorage.getItem("tc:privacy") || "off");
        root.setAttribute("data-tz", localStorage.getItem("tc:tz") || "local"); // dashboard default: local

        const pad = (n) => String(n).padStart(2, "0");
        const fmt = (d, style, utc) => {
          const Y = utc ? d.getUTCFullYear() : d.getFullYear();
          const Mo = pad((utc ? d.getUTCMonth() : d.getMonth()) + 1);
          const Da = pad(utc ? d.getUTCDate() : d.getDate());
          const H = pad(utc ? d.getUTCHours() : d.getHours());
          const Mi = pad(utc ? d.getUTCMinutes() : d.getMinutes());
          const S = pad(utc ? d.getUTCSeconds() : d.getSeconds());
          if (style === "time") return `${H}:${Mi}:${S}`;
          if (style === "date") return `${Y}-${Mo}-${Da}`;
          return `${Y}-${Mo}-${Da} ${H}:${Mi}:${S}`;
        };
        const zoneLabel = (utc) => {
          if (utc) return "UTC";
          try { return Intl.DateTimeFormat().resolvedOptions().timeZone || "local"; } catch (e) { return "local"; }
        };
        const applyTimes = () => {
          const utc = (root.getAttribute("data-tz") || "local") === "utc";
          document.querySelectorAll("[data-utc]").forEach((el) => {
            const iso = el.getAttribute("data-utc");
            if (!iso) return;
            const d = new Date(iso);
            if (isNaN(d.getTime())) return;
            const txt = fmt(d, el.getAttribute("data-utc-style") || "datetime", utc);
            if (el.textContent !== txt) el.textContent = txt;
          });
          document.querySelectorAll("[data-tz-zone]").forEach((el) => {
            const txt = zoneLabel(utc);
            if (el.textContent !== txt) el.textContent = txt;
          });
        };

        document.addEventListener("click", (e) => {
          const p = e.target.closest("[data-privacy-set]");
          if (p) {
            const m = p.getAttribute("data-privacy-set");
            root.setAttribute("data-privacy", m);
            try { localStorage.setItem("tc:privacy", m); } catch (_) {}
            return;
          }
          const t = e.target.closest("[data-tz-toggle]");
          if (t) {
            const m = (root.getAttribute("data-tz") || "local") === "utc" ? "local" : "utc";
            root.setAttribute("data-tz", m);
            try { localStorage.setItem("tc:tz", m); } catch (_) {}
            applyTimes();
          }
        });

        let raf;
        const schedule = () => { if (!raf) raf = requestAnimationFrame(() => { raf = null; applyTimes(); }); };
        const start = () => {
          applyTimes();
          // LiveView re-renders timestamps as UTC on each patch; reformat them.
          new MutationObserver(schedule).observe(document.body, { childList: true, subtree: true, characterData: true });
        };
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", start);
        } else {
          start();
        }
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
